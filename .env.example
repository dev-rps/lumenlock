# LumenLock Environment Configuration
# Copy this file to .env.local and fill in all values.

# ─── Stellar Network ──────────────────────────────────────────────────────────
# Network to connect to: "testnet" | "mainnet" | "futurenet"
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Stellar RPC endpoint
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Stellar Horizon endpoint (for account info, SEP operations)
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Network passphrase
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ─── Contract Addresses (populated after deployment) ──────────────────────────
# Run scripts/deploy-testnet.sh and paste the resulting addresses here.
NEXT_PUBLIC_MARKETPLACE_REGISTRY_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAFCT4

NEXT_PUBLIC_ESCROW_VAULT_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAFCT4

# ─── Supported Token Addresses ────────────────────────────────────────────────
# XLM native SAC address on testnet
NEXT_PUBLIC_XLM_TOKEN_ADDRESS=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCAM

# USDC testnet address (Circle USDC on Stellar testnet)
NEXT_PUBLIC_USDC_TOKEN_ADDRESS=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# ─── Application ─────────────────────────────────────────────────────────────
# Application URL (for SEO and canonical links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Block explorer base URL
NEXT_PUBLIC_EXPLORER_URL=https://stellar.expert/explorer/testnet

# ─── Observability ───────────────────────────────────────────────────────────
# Optional: Sentry DSN for error tracking
SENTRY_DSN=

# Optional: Log level (debug|info|warn|error)
LOG_LEVEL=info

# ─── Admin (server-side only, never expose to browser) ───────────────────────
# Admin secret key (for deployment scripts only, never in frontend)
# ADMIN_SECRET_KEY=S...
